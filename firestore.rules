rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // User: { name, email, role, outletIds, permissions, createdAt }
    // Outlet: { name, address, country, currency, createdAt }
    // Vendor: { name, category, outletId, createdAt }
    // Bill: { vendorId, outletId, amount, status, ... }
    // Settlement: { outletId, date, totalSales, status, ... }
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner() {
      return isAuthenticated() && (
        getUserData().role == 'owner' || 
        (request.auth.token.email == "kapicoast@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isManager() {
      return isAuthenticated() && (getUserData().role == 'manager' || isOwner());
    }

    function hasPermission(permission) {
      return isAuthenticated() && (
        isManager() || 
        (getUserData().permissions != null && getUserData().permissions[permission] == true)
      );
    }

    function isLinkedToOutlet(outletId) {
      return isAuthenticated() && (
        isOwner() || 
        (getUserData().outletIds != null && outletId in getUserData().outletIds)
      );
    }

    // Rules
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isOwner());
      allow write: if isOwner();
    }

    match /outlets/{outletId} {
      allow read: if isAuthenticated() && isLinkedToOutlet(outletId);
      allow write: if isOwner();
    }

    match /vendors/{vendorId} {
      allow read: if isAuthenticated() && isLinkedToOutlet(resource.data.outletId);
      allow create: if isAuthenticated() && hasPermission('manage_vendors') && isLinkedToOutlet(request.resource.data.outletId);
      allow update, delete: if isAuthenticated() && hasPermission('manage_vendors') && isLinkedToOutlet(resource.data.outletId);
    }

    match /bills/{billId} {
      allow read: if isAuthenticated() && isLinkedToOutlet(resource.data.outletId);
      allow create: if isAuthenticated() && hasPermission('upload_bills') && isLinkedToOutlet(request.resource.data.outletId);
      allow update: if isAuthenticated() && (
        (hasPermission('approve_bills') && isLinkedToOutlet(resource.data.outletId)) ||
        (hasPermission('upload_bills') && resource.data.status == 'pending' && isLinkedToOutlet(resource.data.outletId))
      );
      allow delete: if isOwner();
    }

    match /settlements/{settlementId} {
      allow read: if isAuthenticated() && isLinkedToOutlet(resource.data.outletId);
      allow create: if isAuthenticated() && hasPermission('view_settlements') && isLinkedToOutlet(request.resource.data.outletId);
      allow update: if isAuthenticated() && isManager() && isLinkedToOutlet(resource.data.outletId);
      allow delete: if isOwner();
    }
  }
}
